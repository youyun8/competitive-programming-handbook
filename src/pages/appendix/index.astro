---
import { Code } from 'astro:components';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/lib/site';

const bigIntegerCode = `#include <boost/multiprecision/cpp_int.hpp>
using boost::multiprecision::cpp_int;

cpp_int factorial(int number) {
    cpp_int result = 1;
    for (int value = 2; value <= number; ++value) {
        result *= value;
    }
    return result;
}`;

const generatorCode = `std::uint64_t seed = 20260716;
std::mt19937_64 random_engine(seed);
std::uniform_int_distribution<int> distribution(-100, 100);

std::sort(values.begin(), values.end());
values.erase(std::unique(values.begin(), values.end()), values.end());`;

const fastIoCode = `std::ios::sync_with_stdio(false);
std::cin.tie(nullptr);`;
---

<BaseLayout title="附錄 A：C++ 競賽工程技巧">
  <nav class="breadcrumb" aria-label="麵包屑">
    <a href={withBase('/')}>首頁</a><span>/</span><span>附錄 A</span>
  </nav>
  <p class="eyebrow">Appendix A · C++17/C++20</p>
  <h1>C++ 競賽工程技巧</h1>
  <p class="lede">整理大數、測資生成、差分測試與 I/O 等實戰工程技巧。</p>

  <h2>A.1 大數計算</h2>
  <p>
    `boost::multiprecision::cpp_int`
    提供任意精度整數，可直接做加減乘除、位元運算與輸入輸出。它沒有固定上限，但時間與記憶體成本會隨位數成長，也不能直接混用所有標準數學函式。
  </p>
  <Code code={bigIntegerCode} lang="cpp" theme="github-dark-default" />
  <div class="callout">
    若題目只需要十進位加減，可以用低位在前的 <code>vector&lt;int&gt;</code
    >；若需要高效乘法與除法，手寫成本很高，先確認題目是否其實只要求取模。
  </div>

  <h2>A.2 建構測試資料與對拍</h2>
  <p>
    固定 seed 是重現錯誤的關鍵。亂數之外，還要主動加入空間最小值、最大值、重複值、已排序、反向排序與答案在邊界等測資。
  </p>
  <Code code={generatorCode} lang="cpp" theme="github-dark-default" />
  <p>差分測試把小資料交給明顯正確的暴力解與待驗證的最佳化解。發現不一致時，輸出 seed、測試編號與完整輸入後立刻停止。</p>

  <h2>A.3 高效輸入／輸出</h2>
  <Code code={fastIoCode} lang="cpp" theme="github-dark-default" />
  <p>
    關閉同步後不要再混用 <code>scanf/printf</code> 與
    <code>cin/cout</code>。大量逐行輸出可先累積到字串；互動題則要在每次詢問後 flush。格式化輸出要留意
    <code>fixed</code>、<code>setprecision</code> 的狀態會持續影響後續輸出。
  </p>

