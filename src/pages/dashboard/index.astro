---
import AccountPanel from '@/components/auth/AccountPanel';
import BaseLayout from '@/layouts/BaseLayout.astro';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Dashboard" wide>
  <p class="eyebrow">Dashboard</p>
  <h1>你的學習摘要</h1>
  <AccountPanel client:load basePath={basePath} />
  <div class="grid" style="margin-top:1rem">
    <section class="card"><h2>章節完成率</h2><p id="dashboard-lessons">載入中…</p></section>
    <section class="card"><h2>題目狀態</h2><p id="dashboard-exercises">載入中…</p></section>
    <section class="card">
      <h2>待複習</h2><p id="dashboard-review">尚無標記為待複習的題目。</p>
    </section>
    <section class="card"><h2>解題筆記</h2><p id="dashboard-notes">載入中…</p></section>
  </div>
  <script>
    import { readGuestSnapshot } from '@/lib/sync/store';

    async function renderDashboard() {
      const snapshot = await readGuestSnapshot();
      const completedLessons = snapshot.lessons.filter(
        (lesson) => lesson.status === 'completed'
      ).length;
      const solvedExercises = snapshot.exercises.filter(
        (exercise) => exercise.status === 'solved'
      ).length;
      const reviewExercises = snapshot.exercises.filter(
        (exercise) => exercise.status === 'needs-review'
      ).length;
      document.querySelector('#dashboard-lessons')!.textContent =
        `已完成 ${completedLessons} 篇核心教學。`;
      document.querySelector('#dashboard-exercises')!.textContent =
        `已解決 ${solvedExercises} 題；共有 ${snapshot.exercises.length} 題留下學習狀態。`;
      document.querySelector('#dashboard-review')!.textContent = reviewExercises
        ? `有 ${reviewExercises} 題標記為待複習。`
        : '尚無標記為待複習的題目。';
      document.querySelector('#dashboard-notes')!.textContent =
        `已為 ${snapshot.notes.length} 題保存解答或思路。`;
    }
    renderDashboard();
  </script>
</BaseLayout>
