---
import { getCollection, render } from 'astro:content';
import SectionGuide from '@/components/lessons/SectionGuide.astro';
import TextbookPractice from '@/components/lessons/TextbookPractice.astro';
import AlgorithmVisualizer from '@/components/visualizers/AlgorithmVisualizer';
import ProgressActions from '@/components/progress/ProgressActions';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { curriculum, sectionSlug } from '@/lib/curriculum';
import { withBase } from '@/lib/site';

export async function getStaticPaths() {
  const entries = await getCollection('lessons');
  return curriculum.chapters.flatMap((chapter) =>
    chapter.sections.map((section) => {
      const lesson = entries.find((item) => item.data.section === section.id);
      return {
        params: { slug: sectionSlug(section) },
        props: { chapter, section, lesson }
      };
    })
  );
}

const { chapter, section, lesson } = Astro.props;
const rendered = lesson ? await render(lesson) : null;
const Content = rendered?.Content;
const allSections = curriculum.chapters.flatMap((item) =>
  item.sections.map((entry) => ({ chapter: item, section: entry }))
);
const currentIndex = allSections.findIndex((item) => item.section.id === section.id);
const previous = allSections[currentIndex - 1];
const next = allSections[currentIndex + 1];
---

<BaseLayout title={lesson?.data.title ?? `${section.id} ${section.title}`}>
  <nav class="breadcrumb" aria-label="麵包屑">
    <a href={withBase('/')}>首頁</a><span aria-hidden="true">/</span><a href={withBase(`/chapters/${chapter.chapter}/`)}
      >第 {chapter.chapter} 章</a
    ><span aria-hidden="true">/</span><span>{section.id}</span>
  </nav>
  <p class="eyebrow">Lesson {section.id}</p>
  <h1>{lesson?.data.title ?? section.title}</h1>
  <p class="lede">{lesson?.data.summary ?? `本節涵蓋：${section.topics.join('、')}。`}</p>
  <div class="meta">
    <span>{chapter.volume === 'upper' ? '上冊' : '下冊'}</span>
    <span>書頁 {lesson?.data.source_book_pages.join('–') ?? chapter.book_pages.join('–')}</span>
    <span>PDF 頁 {lesson?.data.source_pdf_pages.join('–') ?? chapter.pdf_pages.join('–')}</span>
    <span class="badge verified">{lesson ? '深度教學' : '核心導讀'}</span>
  </div>
  <ProgressActions client:load lessonId={lesson?.data.id ?? `section-${section.id}`} />
  {
    lesson && Content ? (
      <>
        {lesson.data.visualizer && <AlgorithmVisualizer client:visible kind={lesson.data.visualizer} />}
        <Content />
      </>
    ) : (
      <>
        <SectionGuide chapter={chapter} section={section} />
      </>
    )
  }
  <TextbookPractice chapter={chapter} section={section} />
  <nav class="page-actions" aria-label="前後教學">
    {
      previous && (
        <a class="button secondary" href={withBase(`/lessons/${sectionSlug(previous.section)}/`)}>
          ← {previous.section.id} {previous.section.title}
        </a>
      )
    }
    {
      next && (
        <a class="button secondary" href={withBase(`/lessons/${sectionSlug(next.section)}/`)}>
          {next.section.id} {next.section.title} →
        </a>
      )
    }
  </nav>
</BaseLayout>
