---
import { Code } from 'astro:components';
import type { CurriculumChapter, CurriculumSection } from '@/lib/curriculum';

interface Props {
  chapter: CurriculumChapter;
  section: CurriculumSection;
}

const { chapter, section } = Astro.props;

const chapterGuides: Record<
  number,
  {
    signal: string;
    model: string;
    invariant: string;
    complexity: string;
    mistakes: string[];
    code: string;
  }
> = {
  1: {
    signal: '題目要求頻繁插入、刪除、取出端點、維護最值，或以樹狀關係組織資料。',
    model: '先把操作介面寫清楚，再選擇能讓最常見操作便宜的儲存方式；不要只因名稱熟悉就套容器。',
    invariant:
      '每次操作後，元素之間的連結、索引或父子關係仍合法，且空結構與單一元素不需特判才能維持。',
    complexity: '逐一列出建立、查詢、插入、刪除與更新的成本，並分清楚最壞、平均與攤銷複雜度。',
    mistakes: [
      '忽略空結構與最後一個元素',
      '保存了會因擴容或刪除而失效的 iterator／指標',
      '選了方便但複雜度不符合限制的 STL 容器'
    ],
    code: `template <class Value>
struct DataStructure {
    void insert(const Value& value) {
        // 更新儲存內容，同時維持結構不變量。
    }

    bool empty() const {
        // 空結構也必須有明確語意。
        return true;
    }
};`
  },
  2: {
    signal: '輸入具排序、單調、可分割、可局部選擇或可預先累積的性質，暴力枚舉又超出限制。',
    model:
      '先找能刪除重複工作的結構：縮小候選範圍、重用前次結果、分治合併，或證明局部決策不傷害全域答案。',
    invariant:
      '每一步排除的候選都不可能屬於正確答案；若演算法保留一個區間或摘要，真正答案始終仍被它涵蓋。',
    complexity: '從「每個元素被處理幾次」或遞迴樹的層數計算成本，避免只看巢狀迴圈外觀。',
    mistakes: [
      '沒有先證明單調性或貪心選擇性質',
      '混用閉區間與半開區間',
      '預處理很快但每次查詢仍退化成線性'
    ],
    code: `template <class State>
State solve(std::vector<State> values) {
    // 1. 建立可利用的順序或摘要。
    // 2. 維持候選集合的不變量。
    // 3. 每一步嚴格縮小尚未處理的範圍。
    State answer{};
    return answer;
}`
  },
  3: {
    signal:
      '答案藏在狀態空間中，需要判斷可達、最少步數、枚舉方案，或在巨大搜尋樹中找一條可行路徑。',
    model:
      '把問題拆成「狀態、轉移、起點、終止條件、判重」五件事；BFS、DFS 與啟發式搜尋只是在選擇下一個展開狀態。',
    invariant:
      'frontier 只存待展開狀態；已判重的狀態不重複加入。若要求最短路，還要保證取出順序與距離定案條件相容。',
    complexity:
      '以上界估計可達狀態數與每個狀態的轉移數；剪枝必須分析最壞情況，而不是只看平均跑得快。',
    mistakes: [
      '狀態表示缺少影響未來的資訊',
      '出隊才判重造成大量重複入隊',
      '剪枝條件會錯刪仍可能得到答案的分支'
    ],
    code: `struct State {
    // 只保存會影響後續轉移的資訊。
};

void search(const State& start) {
    std::queue<State> frontier;
    frontier.push(start);
    while (!frontier.empty()) {
        State current = frontier.front();
        frontier.pop();
        // 產生合法下一步並在加入 frontier 前判重。
    }
}`
  },
  4: {
    signal:
      '需要大量動態查詢與更新，普通陣列或每次重算無法通過，而操作具有可合併、可分塊或樹上路徑結構。',
    model: '決定每個節點或區塊要保存的最小摘要，以及摘要如何合併、拆分、延遲更新或重建。',
    invariant:
      '結構中的摘要永遠等於其負責範圍的真實答案；若使用 lazy tag，節點值已反映標記，而子節點可在需要時再接收。',
    complexity: '同時計算單次操作、建構成本與記憶體；平衡樹類結構要分清最壞、期望與攤銷保證。',
    mistakes: [
      '節點摘要不足以合併答案',
      'push／pull 的時機不一致',
      '遞迴深度、節點池或常數超出資源限制'
    ],
    code: `struct Node {
    long long summary = 0;
};

Node combine(const Node& left, const Node& right) {
    Node result;
    // result.summary 必須只由兩個子摘要算出。
    return result;
}`
  },
  5: {
    signal: '題目要求計數、最值或可行性，決策分階段且不同遞迴分支會遇到相同子問題。',
    model: '依序回答：狀態代表什麼、從哪裡轉移、初始值、計算順序、最終答案在哪裡。',
    invariant: '計算某狀態時，它依賴的狀態都已正確完成；狀態保存的資訊足以決定所有後續選擇。',
    complexity: '狀態數乘上每個狀態檢查的轉移數；優化的本質通常是減少其中一項。',
    mistakes: [
      '狀態定義有歧義或漏掉關鍵歷史',
      '不可達狀態的初值參與運算',
      '原地更新破壞本輪仍要使用的舊值'
    ],
    code: `std::vector<long long> dp(state_count, impossible);
dp[start_state] = 0;

for (int state = 0; state < state_count; ++state) {
    if (dp[state] == impossible) continue;
    // 依拓撲順序更新 next_state。
}`
  },
  6: {
    signal: '問題涉及整數整除、同餘、質因數、快速冪、線性方程或大範圍算術函數求和。',
    model: '先寫出數學等式與存在條件，再把它轉成可計算步驟；特別標明運算所在的模數、範圍與型別。',
    invariant:
      '每次化簡都保持原方程或同餘關係等價；乘除前確認逆元存在，所有餘數採一致的正規化方式。',
    complexity: '依位數、質數數量、篩法上界或商值分段數分析，不把大整數基本運算誤當成常數。',
    mistakes: ['把模除法當一般整數除法', '乘法在取模前溢位', '忽略非互質情況、負餘數或無解條件'],
    code: `long long normalize(long long value, long long modulus) {
    value %= modulus;
    if (value < 0) value += modulus;
    return value;
}

// 每次乘法前評估是否需要 __int128。
`
  },
  7: {
    signal: '題目在問方案數、排列組合、對稱下本質不同的物件，或雙方輪流操作的勝負。',
    model:
      '先定義「哪些物件算不同」與是否有順序、重複、限制；再選擇直接計數、容斥、生成函數或群作用。',
    invariant: '每個合法物件恰好被計算一次；若使用容斥或等價類，權重與代表的定義在整個推導中一致。',
    complexity: '除了程式迴圈，也要估計子集合、分割數、狀態數與多項式次數是否可承受。',
    mistakes: [
      '混淆排列與組合',
      '除法取模時未確認逆元',
      '對稱計數中忽略固定點或把等價物件重複計入'
    ],
    code: `long long count_objects(const Input& input) {
    // 先定義計數集合，再決定每個物件被加入幾次。
    long long answer = 0;
    return answer;
}`
  },
  8: {
    signal: '輸入是點、線、圓或空間物件，需要判斷方向、相交、距離、包含關係或外層邊界。',
    model: '把幾何判斷化為向量、內積、叉積與參數式；先決定整數精確運算或浮點誤差策略。',
    invariant: '所有方向與座標系約定一致；比較浮點數使用同一個 epsilon，且退化情況另有明確定義。',
    complexity: '通常由排序、枚舉點對或資料結構查詢主導；也要評估座標乘積是否溢位。',
    mistakes: ['叉積方向號誌前後不一', '忽略共線、重合、切線或零長度向量', '直接用 == 比較浮點數'],
    code: `struct Point {
    long long x = 0;
    long long y = 0;
};

long long cross(const Point& a, const Point& b, const Point& c) {
    return (b.x - a.x) * (c.y - a.y)
         - (b.y - a.y) * (c.x - a.x);
}`
  },
  9: {
    signal: '需要模式匹配、前後綴、回文、字典、多模式查找、子字串排序或不同子字串統計。',
    model: '利用相同前綴共享狀態，或替每個位置保存最長可延伸資訊；關鍵是失配時重用已知結果。',
    invariant: '狀態精確代表目前已匹配的前綴、後綴或等價子字串集合；轉移後不遺失仍可能延伸的候選。',
    complexity: '以字串總長、字元集大小與狀態數分析；陣列轉移和 map 轉移有不同常數與記憶體成本。',
    mistakes: [
      '混淆字元索引與字串長度',
      '失配跳轉沒有嚴格縮短候選',
      '雜湊未處理碰撞風險或負值正規化'
    ],
    code: `std::vector<int> build_string_state(const std::string& text) {
    std::vector<int> state(text.size());
    for (int index = 1; index < static_cast<int>(text.size()); ++index) {
        // 利用較短的已知前後綴狀態。
    }
    return state;
}`
  },
  10: {
    signal: '物件與關係自然形成圖，需要回答順序、連通、路徑、環、匹配、容量或選擇衝突。',
    model: '先決定頂點與邊的語意、方向和權重，再依要求選擇遍歷、鬆弛、生成樹、強連通或流量模型。',
    invariant:
      '每個已定案的圖上結論都有可證明的條件；例如最短距離、入度、low-link 或殘量容量的意義不混用。',
    complexity: '以 V、E 與資料結構操作成本表示；先判斷稠密圖或稀疏圖，再選鄰接矩陣或鄰接串列。',
    mistakes: [
      '把無向邊只加入一次',
      '演算法前提與邊權或圖類型不符',
      '沒有保存反向邊、父邊或重邊資訊'
    ],
    code: `struct Edge {
    int to = 0;
    long long weight = 0;
};

std::vector<std::vector<Edge>> graph(vertex_count);
// 建圖時先確認方向、重邊、自環與索引範圍。
`
  }
};

