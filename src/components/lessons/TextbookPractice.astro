---
import type { CurriculumChapter, CurriculumSection } from '@/lib/curriculum';
import { chapterExerciseSolutions } from '@/lib/chapter-exercise-solutions';
import { chapterWorkshops } from '@/lib/chapter-workshops';

interface Props {
  chapter: CurriculumChapter;
  section: CurriculumSection;
}

const { chapter, section } = Astro.props;
const workshop = chapterWorkshops[chapter.chapter]!;
const sectionIndex = chapter.sections.findIndex((item) => item.id === section.id);
const example = workshop.examples[sectionIndex % workshop.examples.length]!;
const exercises = [0, 1].map(
  (offset) => workshop.exercises[(sectionIndex * 2 + offset) % workshop.exercises.length]!
);
const normalizeTitle = (title: string) => title.replace(/\s+/g, '');
---

<section class="textbook-practice" aria-labelledby="textbook-practice-title">
  <h2 id="textbook-practice-title">教材範例與習題</h2>
  <p>
    以下內容依本節主題「{section.topics.join('、')}」重新編寫；題意、推導與解答皆為本站原創整理。
  </p>

  <article class="card worked-example">
    <p class="eyebrow">{example.sourceLabel} · 改寫導讀</p>
    <h3>{example.title}</h3>
    <p>{example.setup}</p>
    <h4>參考解答</h4>
    <ol>
      {example.reasoning.map((step) => <li>{step}</li>)}
    </ol>
    <p><strong>結論：</strong>{example.takeaway}</p>
    <p class="meta">
      來源識別 {chapter.volume === 'upper' ? 'upper-volume' : 'lower-volume'} · 書頁 {
        example.sourceBookPages.join('、')
      } · PDF 頁 {example.sourcePdfPages.join('、')} · reviewed
    </p>
  </article>

  <div class="grid exercise-grid">
    {
      exercises.map((exercise) => {
        const solution = chapterExerciseSolutions[normalizeTitle(exercise.title)];
        return (
          <article class="card">
            <span class="badge">{exercise.level}</span>
            <h3>{exercise.title}</h3>
            <p>{exercise.prompt}</p>
            <p class="meta">訓練重點：{exercise.focus}</p>
            {solution ? (
              <>
                <h4>演算法</h4>
                <p>{solution.approach}</p>
                <h4>正確性</h4>
                <p>{solution.correctness}</p>
                <h4>複雜度</h4>
                <p>{solution.complexity}</p>
              </>
            ) : (
              <p>先依「{exercise.focus}」建立不變量，再逐步驗證每次更新不會排除正確答案。</p>
            )}
          </article>
        );
      })
    }
  </div>
</section>

<style>
  .textbook-practice {
    margin-top: 2.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }

  .worked-example {
    margin: 1rem 0;
  }

  .worked-example,
  .exercise-grid article {
    scroll-margin-top: 5rem;
  }

  .exercise-grid {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 20rem), 1fr));
  }

  .exercise-grid h4 {
    margin-bottom: 0.2rem;
  }

  .exercise-grid article p {
    margin-top: 0.2rem;
  }
</style>
