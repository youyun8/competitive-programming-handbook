{
  "name": "competitive-programming-handbook",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist && tsx scripts/validate/html.ts",
    "preview": "astro preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && pnpm validate:repo",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "validate:repo": "tsx scripts/validate/repository.ts",
    "validate:content": "tsx scripts/validate/content.ts",
    "validate:cpp": "tsx scripts/validate/cpp.ts",
    "validate:html": "tsx scripts/validate/html.ts",
    "validate:secrets": "tsx scripts/validate/secrets.ts",
    "extract:pdf": "python3 scripts/pdf/extract.py",
    "content:stats": "tsx scripts/content/stats.ts",
    "content:candidates": "tsx scripts/content/build-exercise-candidates.ts",
    "content:textbook": "tsx scripts/content/build-textbook-catalog.ts",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm validate:content && pnpm validate:cpp && pnpm build"
  },
  "dependencies": {
    "@astrojs/mdx": "7.0.3",
    "@astrojs/react": "6.0.1",
    "@astrojs/sitemap": "^3.6.0",
    "@supabase/supabase-js": "2.110.6",
    "astro": "7.0.9",
    "idb": "^8.0.3",
    "katex": "^0.16.25",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "^6.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@astrojs/check": "0.9.9",
    "@astrojs/markdown-remark": "7.2.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "globals": "^16.5.0",
    "pagefind": "1.5.2",
    "prettier": "3.7.4",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "4.1.10",
    "yaml": "^2.8.2"
  }
}
